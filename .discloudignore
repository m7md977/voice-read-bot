# Discloud builds from source (BUILD=npm run build), so the TypeScript
# sources and tsconfig.json MUST be uploaded — do not ignore them.

# Git & editor tooling
.git/
.gitignore
.discloudignore
.vscode/
.idea/

# Dependencies (Discloud installs these automatically)
node_modules/

# Local build output (Discloud compiles fresh on deploy)
build/
dist/

# Secrets — set these in the Discloud dashboard, never upload them
.env
.env.*

# Documentation & website (not needed to run the bot)
docs/
*.md
index.html
assets/

# Archives, logs, OS files
*.zip
*.log
logs/
.DS_Store
Thumbs.db
Desktop.ini
